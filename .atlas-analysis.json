  "keyFeatures": [
    "60+ Unix-like commands (ls, grep, curl, tar, etc.)",
    "Virtual filesystem with POSIX-like semantics",
    "bash-like shell with pipes, redirects, and job control",
    "IndexedDB persistence for filesystem state",
    "Node.js compatibility layer for running JavaScript",
    "Package manager for extending functionality",
    "Sandbox API for programmatic control",
    "Browser-native architecture (no WASM, no emulation)"
  ],
  "publicApiSurface": [
    "Sandbox.create()",
    "Sandbox.commands.run()",
    "Sandbox.fs.readFile()",
    "Sandbox.fs.writeFile()",
    "Kernel.boot()",
    "VFS.readFile()",
